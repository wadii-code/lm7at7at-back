# Backend Environment Variables
# Copy this to .env and fill in your values

# Supabase (get from dashboard.project.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# JWT Secret (generate strong random string, at least 32 chars)
JWT_SECRET=your_very_secure_jwt_secret_key_here_change_this_immediately

# Port (optional, defaults to 3001)
PORT=3001

# Example: SUPABASE_URL=https://abc123.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# JWT_SECRET=mySuperSecretKeyThatIsAtLeast32CharactersLong123456

